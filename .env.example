DATABASE_URL=postgresql://market_user:market_pass@localhost:5432/market

# Path to data-store repo (for running scrape scripts)
# DATA_STORE_DIR=/path/to/data-store

# Fyers API (for OHLCV data) — APP_ID and SECRET already set as defaults in code
FYERS_CLIENT_ID=your_fyers_client_id
FYERS_SECRET_KEY=your_fyers_secret_key
FYERS_REDIRECT_URI=https://www.google.com/
# FYERS_TOKEN_FILE=/path/to/data-store/fyers_access_token.txt

# Fyers TOTP automation (set these to enable auto-generate without browser)
FYERS_USERNAME=your_fyers_login_id
FYERS_PIN=your_4_digit_pin
FYERS_TOTP_KEY=your_totp_secret_key
